{
  "name": "frontend",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "backend:dev": "node ./scripts/run-backend-dev.mjs",
    "dev": "vite",
    "build": "vite build",
    "start": "vite preview",
    "desktop:dev": "npm run dev",
    "desktop:build": "npm run build",
    "desktop:tauri-dev": "node ./scripts/run-tauri-dev.mjs",
    "desktop:tauri-build": "npm run tauri:prepare-backend:clean && npm run build",
    "tauri:prepare-backend": "python ../backend/scripts/stage_tauri_sidecar.py",
    "tauri:prepare-backend:clean": "python ../backend/scripts/stage_tauri_sidecar.py --force --clean",
    "tauri:dev": "node ./scripts/run-tauri-cli-dev.mjs",
    "tauri:dev:sidecar": "node ./scripts/run-tauri-cli-dev.mjs --mode sidecar",
    "tauri:build": "tauri build",
    "lint": "eslint",
    "test": "vitest run",
    "postinstall": "patch-package",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "rm -f tsconfig.tsbuildinfo && tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.1",
    "patch-package": "^8.0.1",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.0"
  }
}
